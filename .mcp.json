{
  "mcpServers": {
    "linear": {
      "command": "npx",
      "args": ["-y", "mcp-remote@0.1.38", "https://mcp.linear.app/mcp"]
    },
    "MotherDuck": {
      "command": "uvx",
      "args": ["mcp-server-motherduck", "--db-path", "md:"],
      "env": {
        "motherduck_token": "${MOTHERDUCK_ACCESS_TOKEN}"
      }
    }
  }
}
